<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" /> 
<title>Forms &middot; AFEX Hub</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://api.fontshare.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,500;1,600;1,700&display=swap" rel="stylesheet">
<link href="https://api.fontshare.com/v2/css?f[]=switzer@400,500,600,700,800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="../assets/shared.css">
<style>
  .page-head{ margin-bottom:36px; }
  .page-title{ font-family:'Cormorant Garamond',serif; font-style:italic; font-weight:700; font-size:clamp(2.4rem,5vw,3.6rem); line-height:1.1; letter-spacing:-.01em;
    background:linear-gradient(100deg,var(--red-deep),var(--rose)); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; color:transparent; padding-bottom:.08em; }
  .page-sub{ font-size:.95rem; color:var(--soft); font-weight:500; margin-top:.4rem; }

  .section-label{ font-size:.78rem; letter-spacing:.14em; text-transform:uppercase; color:var(--soft); font-weight:700; margin:8px 0 18px; }

  .form-grid{ display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:16px; margin-bottom:44px; }
  .form-card{ display:flex; flex-direction:column; gap:14px; cursor:pointer; text-decoration:none; color:inherit;
    transition:transform .3s var(--ease); }
  .form-card:hover{ transform:translateY(-4px); }
  .form-icon{ width:46px; height:46px; border-radius:13px; display:flex; align-items:center; justify-content:center;
    background:linear-gradient(135deg,var(--red),var(--rose)); color:#fff; position:relative; z-index:1; }
  .form-icon svg{ width:22px; height:22px; }
  .form-name{ font-size:1.1rem; font-weight:700; letter-spacing:-.01em; position:relative; z-index:1; }
  .form-desc{ font-size:.84rem; color:var(--soft); font-weight:500; line-height:1.5; position:relative; z-index:1; }
  .form-go{ font-size:.82rem; font-weight:700; color:var(--red); margin-top:auto; position:relative; z-index:1; display:inline-flex; align-items:center; gap:6px; }

  .doc-list{ display:flex; flex-direction:column; gap:10px; }
  .doc-row{ display:flex; align-items:center; gap:16px; padding:16px 20px; text-decoration:none; color:inherit;
    transition:transform .25s var(--ease); }
  .doc-row:hover{ transform:translateX(4px); }
  .doc-ic{ width:38px; height:38px; border-radius:10px; flex-shrink:0; display:flex; align-items:center; justify-content:center;
    background:rgba(201,6,58,.09); color:var(--red); position:relative; z-index:1; }
  .doc-ic svg{ width:18px; height:18px; }
  .doc-meta{ position:relative; z-index:1; flex:1; }
  .doc-name{ font-size:.95rem; font-weight:700; }
  .doc-type{ font-size:.76rem; color:var(--soft); font-weight:600; margin-top:2px; }
  .doc-dl{ font-size:.8rem; font-weight:700; color:var(--red); position:relative; z-index:1; }
</style>
</head>
<body>
  <div class="page">
    <div class="aura" aria-hidden="true">
      <div class="wash" style="width:44vw;height:44vw;right:-8vw;top:-12vh;background:radial-gradient(circle at center,rgba(201,6,58,.22),transparent 64%);animation:wf3 34s ease-in-out infinite;"></div>
      <div class="wash" style="width:40vw;height:40vw;left:-6vw;bottom:-16vh;background:radial-gradient(circle at center,rgba(244,63,111,.2),transparent 64%);animation:wf2 40s ease-in-out infinite;"></div>
      <div class="wash" style="width:38vw;height:38vw;left:36vw;top:30vh;background:radial-gradient(circle at center,rgba(255,138,170,.18),transparent 62%);animation:wf1 46s ease-in-out infinite;"></div>
    </div>
    <div class="grain" aria-hidden="true" style="z-index:1;"></div>
    <div class="sheen" aria-hidden="true" style="z-index:1;"></div>

    <div class="page-content">
      <span id="nav-slot"></span>

      <div class="page-head">
        <div class="page-title">Forms</div>
        <div class="page-sub">Start a new registration, submission, or request. Everything routes straight to the right place.</div>
      </div>

      <div class="section-label">Submit a Form</div>
      <div class="form-grid">
        <a class="card form-card" href="#" target="_blank" rel="noopener">
          <div class="form-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg></div>
          <div class="form-name">Registration Form</div>
          <div class="form-desc">Register a new borrower and kick off their file.</div>
          <span class="form-go">Open form &rarr;</span>
        </a>
        <a class="card form-card" href="#" target="_blank" rel="noopener">
          <div class="form-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg></div>
          <div class="form-name">Submission Form</div>
          <div class="form-desc">Submit a completed file for processing.</div>
          <span class="form-go">Open form &rarr;</span>
        </a>
        <a class="card form-card" href="#" target="_blank" rel="noopener">
          <div class="form-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 22V12h6v10"/></svg></div>
          <div class="form-name">Appraisal Request</div>
          <div class="form-desc">Order an appraisal for a property in progress.</div>
          <span class="form-go">Open form &rarr;</span>
        </a>
        <a class="card form-card" href="#" target="_blank" rel="noopener">
          <div class="form-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg></div>
          <div class="form-name">Change Request</div>
          <div class="form-desc">Request a change to an existing file or lock.</div>
          <span class="form-go">Open form &rarr;</span>
        </a>
      </div>

      <div class="section-label">Checklists &amp; Documents</div>
      <div class="doc-list">
        <a class="card doc-row" href="#" target="_blank" rel="noopener">
          <div class="doc-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></div>
          <div class="doc-meta"><div class="doc-name">New File Setup Checklist</div><div class="doc-type">PDF &middot; 2 pages</div></div>
          <span class="doc-dl">Download</span>
        </a>
        <a class="card doc-row" href="#" target="_blank" rel="noopener">
          <div class="doc-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></div>
          <div class="doc-meta"><div class="doc-name">Document Collection Checklist</div><div class="doc-type">PDF &middot; 1 page</div></div>
          <span class="doc-dl">Download</span>
        </a>
        <a class="card doc-row" href="#" target="_blank" rel="noopener">
          <div class="doc-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></div>
          <div class="doc-meta"><div class="doc-name">Pre-Submission Review</div><div class="doc-type">PDF &middot; 3 pages</div></div>
          <span class="doc-dl">Download</span>
        </a>
      </div>
    </div>
  </div>
<script src="../assets/nav.js"></script>
<script>
  mountNav('Forms', '../');
</script> 
</body>
</html>
